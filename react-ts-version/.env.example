# Firebase web-app config — copy to .env.local and fill from the Firebase console
# (Project settings → General → Your apps → SDK setup and configuration).
# .env.local is gitignored; never commit real values.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=mathimaticore.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=mathimaticore
VITE_FIREBASE_APP_ID=
