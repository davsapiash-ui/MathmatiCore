{
  "rules": {
    ".read": false,
    ".write": false,

    "students": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || auth.token.role === 'teacher' || auth.token.role === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || auth.token.role === 'teacher' || auth.token.role === 'admin')"
      }
    },

    "radar_alerts": {
      ".read": "auth != null && (auth.token.role === 'teacher' || auth.token.role === 'admin')",
      "$alertId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['type', 'studentId', 'timestamp']) && newData.child('studentId').val() === auth.uid"
      }
    },

    "qMatrixResults": {
      "$studentId": {
        ".read": "auth != null && (auth.uid === $studentId || auth.token.role === 'teacher' || auth.token.role === 'admin')",
        ".write": "auth != null && (auth.uid === $studentId || auth.token.role === 'teacher' || auth.token.role === 'admin')",
        ".validate": "newData.hasChildren(['task1_zero_placeholder', 'task2_estimation_error_margin', 'task3_flexible_regrouping', 'task4_basic_addition_fluency', 'task5_basic_subtraction_fluency'])"
      }
    },

    "traceData": {
      "$studentId": {
        ".read": "auth != null && (auth.uid === $studentId || auth.token.role === 'teacher' || auth.token.role === 'admin')",
        ".write": "auth != null && (auth.uid === $studentId || auth.token.role === 'teacher' || auth.token.role === 'admin')",
        ".validate": "newData.hasChildren(['hesitation_events', 'undo_clicks']) && newData.child('hesitation_events').isNumber() && newData.child('undo_clicks').isNumber()"
      }
    },

    "reflections": {
      ".read": "auth != null && (auth.token.role === 'teacher' || auth.token.role === 'admin')",
      ".write": "auth != null",
      "$reflectionId": {
        ".validate": "newData.hasChildren(['effort', 'strategy', 'timestamp', 'student'])"
      }
    },

    "sessions": {
      ".read": "auth != null && (auth.token.role === 'teacher' || auth.token.role === 'admin')",
      ".write": "auth != null"
    },

    "teachers": {
      "$teacherId": {
        ".read": "auth != null && (auth.uid === $teacherId || auth.token.role === 'admin')",
        ".write": "auth != null && auth.token.role === 'admin'"
      }
    },

    "system_control": {
      ".read": "auth != null && auth.token.role === 'admin'",
      ".write": "auth != null && auth.token.role === 'admin'"
    },

    "audit_logs": {
      ".read": "auth != null && auth.token.role === 'admin'",
      ".write": "auth != null && auth.token.role === 'admin'"
    }
  }
}
