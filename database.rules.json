{
  "rules": {
    ".read": false,
    ".write": false,

    "students": {
      "$studentId": {
        ".read": "auth != null",
        ".write": "auth != null",
        
        "studentId": { ".validate": "newData.isString()" },
        "name": { ".validate": "newData.isString()" },
        "classId": { ".validate": "newData.isString()" },
        "completedMeeting2": { ".validate": "newData.isBoolean()" },
        "routeRecommendation": { ".validate": "newData.isString() || !newData.exists()" },
        "routeStatus": { ".validate": "newData.isString() || !newData.exists()" },
        
        "qMatrixResults": {
          ".validate": "newData.hasChildren(['task1_zero_placeholder', 'task2_estimation_error_margin', 'task3_flexible_regrouping', 'task4_basic_addition_fluency', 'task5_small_change', 'task6_subtraction_regrouping', 'task7_missing_subtrahend', 'task8_missing_addend'])"
        },
        
        "traceData": {
          ".validate": "newData.hasChildren(['hesitation_events', 'undo_clicks']) && newData.child('hesitation_events').isNumber() && newData.child('undo_clicks').isNumber()"
        },
        
        "telemetry_chunks": {
           "$chunkId": {
             ".validate": "newData.hasChildren()"
           }
        }
      }
    },

    "users": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "radar_alerts": {
      ".read": "auth != null",
      "$alertId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['type', 'timestamp'])"
      }
    },

    "reflections": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$reflectionId": {
        ".validate": "newData.hasChildren(['effort', 'strategy', 'timestamp', 'student'])"
      }
    },

    "sessions": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "replays": {
      "$sessionKey": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "chat": {
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "teachers": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "approved_tasks": {
      "$studentId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "ai_pending_approvals": {
      "$teacherId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "system_control": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "audit_logs": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
