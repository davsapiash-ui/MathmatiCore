{
  "rules": {
    ".read": false,
    ".write": false,

    "students": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "radar_alerts": {
      ".read": "auth != null",
      "$alertId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['type', 'timestamp'])"
      }
    },

    "qMatrixResults": {
      "$studentId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['studentId', 'qMatrixResults'])"
      }
    },

    "traceData": {
      "$studentId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['hesitation_events', 'undo_clicks']) && newData.child('hesitation_events').isNumber() && newData.child('undo_clicks').isNumber()"
      }
    },

    "reflections": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$reflectionId": {
        ".validate": "newData.hasChildren(['effort', 'strategy', 'timestamp', 'student'])"
      }
    },

    "sessions": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "replays": {
      "$sessionKey": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "chat": {
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "teachers": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "approved_tasks": {
      "$studentId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "ai_pending_approvals": {
      "$teacherId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "system_control": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "audit_logs": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
