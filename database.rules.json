{
  "rules": {
    ".read": false,
    ".write": false,

    "students": {
      "$studentId": {
        ".read": "auth != null && (auth.token.email === $studentId + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
        
        "studentId": {
          ".write": "auth != null && (auth.token.email === $studentId + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
          ".validate": "newData.isString()"
        },
        "name": {
          ".write": "auth != null && (auth.token.email === $studentId + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
          ".validate": "newData.isString()"
        },
        "classId": {
          ".write": "auth != null && (auth.token.email === $studentId + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
          ".validate": "newData.isString()"
        },
        "completedMeeting2": {
          ".write": "auth != null && (auth.token.email === $studentId + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
          ".validate": "newData.isBoolean()"
        },
        "workspaceState": {
          ".write": "auth != null && (auth.token.email === $studentId + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')"
        },
        "lastActive": {
          ".write": "auth != null && (auth.token.email === $studentId + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')"
        },
        "profile": {
          ".write": "auth != null && (auth.token.email === $studentId + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')"
        },
        "qMatrixResults": {
          ".write": "auth != null && (auth.token.email === $studentId + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')"
        },
        "routeRecommendation": {
          ".write": "auth != null && (root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
          ".validate": "newData.isString() || !newData.exists()"
        },
        "routeStatus": {
          ".write": "auth != null && (auth.token.email === $studentId + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
          ".validate": "newData.isString() || !newData.exists()"
        },
        "telemetry_chunks": {
          ".read": "auth != null && (root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
          "$chunkId": {
            ".write": "auth != null && (auth.token.email === $studentId + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
            ".validate": "newData.hasChildren()"
          }
        }
      }
    },

    "classes": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.email === 'admin@mathmaticore.local'"
    },

    "users": {
      "students": {
        ".read": "auth != null && (root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
        "$studentId": {
          ".read": "auth != null && (auth.token.email === $studentId + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
          "name": {
            ".write": "auth != null && (auth.token.email === $studentId + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')"
          },
          "studentId": {
            ".write": "auth != null && (auth.token.email === $studentId + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')"
          },
          "classId": {
            ".write": "auth != null && (auth.token.email === $studentId + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')"
          },
          "completedMeeting2": {
            ".write": "auth != null && (auth.token.email === $studentId + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')"
          },
          "workspaceState": {
            ".write": "auth != null && (auth.token.email === $studentId + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')"
          },
          "lastActive": {
            ".write": "auth != null && (auth.token.email === $studentId + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')"
          },
          "profile": {
            ".write": "auth != null && (auth.token.email === $studentId + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')"
          },
          "qMatrixResults": {
            ".write": "auth != null && (auth.token.email === $studentId + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
            "$taskName": { ".validate": "newData.isString()" }
          },
          "routeRecommendation": { 
            ".write": "auth != null && (root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
            ".validate": "newData.isString() || !newData.exists()" 
          },
          "routeStatus": { 
            ".write": "auth != null && (auth.token.email === $studentId + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
            ".validate": "newData.isString() || !newData.exists()" 
          },
          "teacher_hint": {
            ".write": "auth != null && (root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')"
          },
          "traceData": {
            ".write": "auth != null && (auth.token.email === $studentId + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
            ".validate": "newData.hasChildren(['hesitation_events', 'undo_clicks']) && newData.child('hesitation_events').isNumber() && newData.child('undo_clicks').isNumber()"
          }
        }
      },
      "teachers": {
        "$teacherId": {
          ".read": "auth != null && (auth.token.email === 'teacher_' + $teacherId + '@mathmaticore.local' || auth.token.email === 'admin@mathmaticore.local')",
          ".write": "auth != null && (auth.token.email === 'admin@mathmaticore.local' || (auth.token.email === 'teacher_' + $teacherId + '@mathmaticore.local' && !data.exists()))"
        }
      }
    },

    "radar_alerts": {
      ".read": "auth != null && (root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
      "$alertId": {
        ".write": "auth != null && (auth.token.email.matches(/.*@mathmaticore\\.local$/) || auth.token.email === 'admin@mathmaticore.local')",
        ".validate": "newData.hasChildren(['type', 'timestamp'])"
      }
    },

    "reflections": {
      ".read": "auth != null && (root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
      ".write": "auth != null && (auth.token.email.matches(/.*@mathmaticore\\.local$/) || auth.token.email === 'admin@mathmaticore.local')",
      "$reflectionId": {
        ".validate": "newData.hasChildren(['effort', 'strategy', 'timestamp', 'student'])"
      }
    },

    "chat_messages": {
      ".read": "auth != null && (root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
      "$roomId": {
        ".read": "auth != null && (auth.token.email === $roomId + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
        "$messageId": {
          ".write": "auth != null && (auth.token.email === $roomId + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local') && (auth.uid === newData.child('senderId').val() || auth.uid === newData.child('receiverId').val() || auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '') === newData.child('senderId').val() || auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '') === newData.child('receiverId').val() || auth.token.email === 'admin@mathmaticore.local' || auth.token.email === newData.child('senderId').val() || auth.token.email === newData.child('receiverId').val() || !newData.exists() || (newData.hasChildren(['read']) && !newData.hasChildren(['senderId', 'receiverId', 'text', 'timestamp'])))"
        }
      }
    },

    "sessions": {
      ".read": "auth != null && (root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
      ".write": "auth != null && auth.token.email === 'admin@mathmaticore.local'"
    },

    "replays": {
      "$sessionKey": {
        ".read": "auth != null && (root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
        ".write": "auth != null && (auth.token.email === $sessionKey + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')"
      }
    },

    "chat": {
      "$roomId": {
        ".read": "auth != null",
        "$messageId": {
          ".write": "auth != null && (auth.uid === newData.child('senderId').val() || auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '') === newData.child('senderId').val() || auth.token.email === 'admin@mathmaticore.local' || auth.token.email === newData.child('senderId').val())"
        }
      }
    },

    "approved_tasks": {
      "$studentId": {
        ".read": "auth != null && (auth.token.email === $studentId + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
        ".write": "auth != null && (root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')"
      }
    },

    "ai_pending_approvals": {
      "$teacherId": {
        ".read": "auth != null && (auth.token.email === 'teacher_' + $teacherId + '@mathmaticore.local' || auth.token.email.replace('@mathmaticore.local','') === $teacherId || auth.token.email === 'admin@mathmaticore.local')",
        ".write": "auth != null && (auth.token.email.matches(/.*@mathmaticore\\.local$/) || auth.token.email === 'admin@mathmaticore.local')"
      }
    },

    "system_control": {
      ".read": "auth != null && auth.token.email === 'admin@mathmaticore.local'",
      ".write": "auth != null && auth.token.email === 'admin@mathmaticore.local'"
    },

    "audit_logs": {
      ".read": "auth != null && auth.token.email === 'admin@mathmaticore.local'",
      ".write": "auth != null"
    }
  }
}
