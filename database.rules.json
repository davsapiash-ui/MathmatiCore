{
  "rules": {
    ".read": false,
    ".write": false,

    "students": {
      "$studentId": {
        ".read": "auth != null && (auth.token.email === $studentId + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
        ".write": "auth != null && (auth.token.email === $studentId + '@mathmaticore.local' || auth.token.email === 'admin@mathmaticore.local')",
        
        "studentId": { ".validate": "newData.isString()" },
        "name": { ".validate": "newData.isString()" },
        "classId": { ".validate": "newData.isString()" },
        "completedMeeting2": { ".validate": "newData.isBoolean()" },
        "routeRecommendation": { ".validate": "newData.isString() || !newData.exists()" },
        "routeStatus": { ".validate": "newData.isString() || !newData.exists()" },
        
        "qMatrixResults": {
          "$taskName": { ".validate": "newData.isString()" }
        },
        
        "traceData": {
          ".validate": "newData.hasChildren(['hesitation_events', 'undo_clicks']) && newData.child('hesitation_events').isNumber() && newData.child('undo_clicks').isNumber()"
        },
        
        "telemetry_chunks": {
           "$chunkId": {
             ".validate": "newData.hasChildren()"
           }
        }
      }
    },

    "users": {
      "students": {
        "$studentId": {
          ".read": "auth != null && (auth.token.email === $studentId + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
          ".write": "auth != null && (auth.token.email === $studentId + '@mathmaticore.local' || auth.token.email === 'admin@mathmaticore.local')"
        }
      },
      "teachers": {
        "$teacherId": {
          ".read": "auth != null && (auth.token.email === 'teacher_' + $teacherId + '@mathmaticore.local' || auth.token.email === 'admin@mathmaticore.local')",
          ".write": "auth != null && auth.token.email === 'admin@mathmaticore.local'"
        }
      }
    },

    "radar_alerts": {
      ".read": "auth != null && (root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
      "$alertId": {
        ".write": "auth != null && (auth.token.email.matches(/.*@mathmaticore\\.local$/) || auth.token.email === 'admin@mathmaticore.local')",
        ".validate": "newData.hasChildren(['type', 'timestamp'])"
      }
    },

    "reflections": {
      ".read": "auth != null && (root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
      ".write": "auth != null && (auth.token.email.matches(/.*@mathmaticore\\.local$/) || auth.token.email === 'admin@mathmaticore.local')",
      "$reflectionId": {
        ".validate": "newData.hasChildren(['effort', 'strategy', 'timestamp', 'student'])"
      }
    },

    "sessions": {
      ".read": "auth != null && (root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
      ".write": "auth != null && auth.token.email === 'admin@mathmaticore.local'"
    },

    "replays": {
      "$sessionKey": {
        ".read": "auth != null && (root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
        ".write": "auth != null && auth.token.email === 'admin@mathmaticore.local'"
      }
    },

    "chat": {
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "approved_tasks": {
      "$studentId": {
        ".read": "auth != null && (auth.token.email === $studentId + '@mathmaticore.local' || root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')",
        ".write": "auth != null && (root.child('users/teachers/' + auth.token.email.replace('teacher_', '').replace('@mathmaticore.local', '')).exists() || auth.token.email === 'admin@mathmaticore.local')"
      }
    },

    "ai_pending_approvals": {
      "$teacherId": {
        ".read": "auth != null && (auth.token.email === 'teacher_' + $teacherId + '@mathmaticore.local' || auth.token.email === 'admin@mathmaticore.local')",
        ".write": "auth != null && auth.token.email === 'admin@mathmaticore.local'"
      }
    },

    "system_control": {
      ".read": "auth != null && auth.token.email === 'admin@mathmaticore.local'",
      ".write": "auth != null && auth.token.email === 'admin@mathmaticore.local'"
    },

    "audit_logs": {
      ".read": "auth != null && auth.token.email === 'admin@mathmaticore.local'",
      ".write": "auth != null && auth.token.email === 'admin@mathmaticore.local'"
    }
  }
}
